{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://retro-short-studio.local/schema/project.schema.json",
  "title": "ProjectDto",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "projectId",
    "projectName",
    "settings",
    "assets",
    "characters",
    "scenes"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "projectId": {
      "type": "string"
    },
    "projectName": {
      "type": "string"
    },
    "settings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "width",
        "height",
        "fps"
      ],
      "properties": {
        "width": {
          "type": "number"
        },
        "height": {
          "type": "number"
        },
        "fps": {
          "type": "number"
        }
      }
    },
    "assets": {
      "type": "array"
    },
    "characters": {
      "type": "array"
    },
    "scenes": {
      "type": "array"
    }
  }
}
