{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "types": ["node", "vitest/globals"]
  },
  "include": [
    "core/src/**/*.ts",
    "shared/**/*.ts",
    "storage/src/**/*.ts",
    "tests/**/*.ts"
  ]
}
